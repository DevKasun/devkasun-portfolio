---
import PageLayout from "../layouts/PageLayout.astro";
import { ABOUT_SITE_TITLE, ABOUT_SITE_DESCRIPTION } from "../consts";
---

<PageLayout title={ABOUT_SITE_TITLE} description={ABOUT_SITE_DESCRIPTION}>
    
    <style>
        .timeline-scroll-path {
            stroke-dasharray: 12 12;
            animation: dash 3s linear infinite;
        }

        @keyframes dash {
            to {
                stroke-dashoffset: -24;
            }
        }

        .node-reveal {
            opacity: 0;
            transform: translateY(30px) scale(0.95);
            transition: all 0.7s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .node-reveal.visible {
            opacity: 1;
            transform: translateY(0) scale(1);
        }

        .node-icon-pulse {
            animation: pulse-ring 2s cubic-bezier(0.215, 0.61, 0.355, 1) infinite;
        }

        @keyframes pulse-ring {
            0% {
                transform: scale(0.95);
                box-shadow: 0 0 0 0 rgba(171, 32, 253, 0.7);
            }
            70% {
                transform: scale(1);
                box-shadow: 0 0 0 10px rgba(171, 32, 253, 0);
            }
            100% {
                transform: scale(0.95);
                box-shadow: 0 0 0 0 rgba(171, 32, 253, 0);
            }
        }
    </style>

    <main class="py-12 pb-32 relative overflow-hidden">
        <div class="container mb-12 lg:mb-20 text-center relative z-10">
            <h1 class="text-3xl lg:text-5xl font-bold font-geistmono tracking-wider text-white drop-shadow-[0_0_15px_rgba(171,32,253,0.5)]">
                EXPERIENCE MAP
            </h1>
            <p class="text-accent mt-2 font-geistmono">Select your character's journey</p>
        </div>
        
        <!-- Winding Background Path SVG for Desktop -->
        <svg class="absolute top-20 left-1/2 -translate-x-1/2 w-[800px] h-[1500px] hidden md:block z-0 opacity-40 pointer-events-none" viewBox="0 0 800 1500" fill="none" preserveAspectRatio="xMidYMin slice">
            <path d="M 400 0 C 700 200, 100 400, 400 600 C 700 800, 100 1000, 400 1200 L 400 1500" stroke="#ab20fd" stroke-width="3" class="timeline-scroll-path" />
        </svg>

        <!-- Straight Background Path SVG for Mobile -->
        <svg class="absolute top-20 left-8 w-1 h-[1500px] md:hidden z-0 opacity-40 pointer-events-none" viewBox="0 0 4 1500" fill="none" preserveAspectRatio="xMidYMin slice">
            <line x1="2" y1="0" x2="2" y2="1500" stroke="#ab20fd" stroke-width="3" class="timeline-scroll-path" />
        </svg>

        <div class="container relative z-10 font-geistmono pb-20 max-w-5xl">
            <div class="flex flex-col gap-24 md:gap-40 lg:gap-56 mt-16 timeline-container">

                <!-- Level 03: Freelance -->
                <div class="node-reveal flex flex-col md:flex-row items-center md:justify-center relative">
                    <!-- Mobile Connecting Line to Icon -->
                    <div class="absolute -left-5 top-10 w-8 h-[2px] bg-accent md:hidden opacity-50"></div>
                    
                    <div class="w-full md:w-5/12 flex md:justify-end md:pr-12 md:text-right pl-12 md:pl-0">
                        <div class="bg-black/60 backdrop-blur-md border border-accent/30 p-6 rounded-lg shadow-[0_0_20px_rgba(171,32,253,0.15)] hover:shadow-[0_0_30px_rgba(171,32,253,0.4)] transition-all duration-300 transform hover:-translate-y-1">
                            <div class="flex flex-col md:items-end mb-4">
                                <div class="flex items-center gap-2 mb-1">
                                    <span class="text-xs font-bold text-accent border border-accent rounded px-2 py-0.5">LVL 03</span>
                                    <span class="text-xs font-bold text-green-400 border border-green-500/50 rounded px-2 py-0.5 bg-green-500/10">ACTIVE</span>
                                </div>
                                <h2 class="text-2xl font-bold text-white mt-1">Freelance</h2>
                                <h3 class="text-lg text-accent font-medium">Frontend Engineer</h3>
                                <span class="text-sm font-semibold text-gray-400 mt-1">Feb 2025 - Present</span>
                            </div>
                            <ul class="text-sm text-gray-300 md:text-right space-y-2">
                                <li><strong class="text-white">Architecture:</strong> Scalable fintech app using React, TypeScript, and Vite with custom hooks.</li>
                                <li><strong class="text-white">Complex State:</strong> Managed high-frequency updates via Recoil & TanStack Query.</li>
                                <li><strong class="text-white">Features:</strong> AG Grid, role-based auth, and i18next multi-currency.</li>
                                <li><strong class="text-white">Quality:</strong> Vitest & CI/CD workflows.</li>
                            </ul>
                        </div>
                    </div>

                    <!-- Icon / Avatar -->
                    <div class="absolute left-0 top-6 md:static md:top-auto shrink-0 z-20 mx-auto md:mx-0 w-16 h-16 md:w-24 md:h-24 bg-black rounded-full border-2 border-accent flex items-center justify-center node-icon-pulse overflow-hidden group shadow-[0_0_15px_rgba(171,32,253,0.6)]">
                        <!-- SVG Avatar Generator for RPG look -->
                        <svg viewBox="0 0 100 100" class="w-10 h-10 md:w-14 md:h-14 text-white group-hover:scale-110 transition-transform duration-300" fill="currentColor">
                            <path d="M50 10 L90 30 L90 70 L50 90 L10 70 L10 30 Z" opacity="0.2" fill="#ab20fd"/>
                            <path d="M50 20 L80 35 L80 65 L50 80 L20 65 L20 35 Z" stroke="#ab20fd" stroke-width="2" fill="none"/>
                            <!-- Abstract Star/Sword core -->
                            <path d="M50 30 L55 45 L70 50 L55 55 L50 70 L45 55 L30 50 L45 45 Z" fill="#ab20fd"/>
                        </svg>
                    </div>

                    <div class="w-full md:w-5/12 hidden md:block pl-12">
                        <!-- Empty spacer for desktop alternating layout -->
                    </div>
                </div>

                <!-- Level 02: Rhino Partners -->
                <div class="node-reveal flex flex-col md:flex-row items-center md:justify-center relative">
                     <!-- Mobile Connecting Line to Icon -->
                     <div class="absolute -left-5 top-10 w-8 h-[2px] bg-accent md:hidden opacity-50"></div>
                     
                    <div class="w-full md:w-5/12 hidden md:block pr-12">
                        <!-- Empty spacer for desktop alternating layout -->
                    </div>

                    <!-- Icon / Avatar -->
                    <div class="absolute left-0 top-6 md:static md:top-auto shrink-0 z-20 mx-auto md:mx-0 w-16 h-16 md:w-24 md:h-24 bg-black rounded-full border-2 border-accent flex items-center justify-center node-icon-pulse overflow-hidden group shadow-[0_0_15px_rgba(171,32,253,0.6)]">
                        <svg viewBox="0 0 100 100" class="w-10 h-10 md:w-14 md:h-14 text-white group-hover:scale-110 transition-transform duration-300" fill="currentColor">
                            <circle cx="50" cy="50" r="40" opacity="0.2" fill="#ab20fd"/>
                            <circle cx="50" cy="50" r="30" stroke="#ab20fd" stroke-width="2" fill="none" stroke-dasharray="5 5"/>
                            <!-- Abstract shield/gem -->
                            <path d="M35 30 L65 30 L75 50 L50 80 L25 50 Z" fill="#ab20fd"/>
                        </svg>
                    </div>

                    <div class="w-full md:w-5/12 pl-12 md:pl-12">
                        <div class="bg-black/60 backdrop-blur-md border border-accent/30 p-6 rounded-lg shadow-[0_0_20px_rgba(171,32,253,0.15)] hover:shadow-[0_0_30px_rgba(171,32,253,0.4)] transition-all duration-300 transform hover:-translate-y-1 relative">
                            <!-- Connector line for desktop -->
                            
                            <div class="flex flex-col mb-4">
                                <div class="flex items-center gap-2 mb-1">
                                    <span class="text-xs font-bold text-accent border border-accent rounded px-2 py-0.5">LVL 02</span>
                                    <span class="text-xs font-bold text-gray-400 border border-gray-600 rounded px-2 py-0.5 bg-gray-600/10">CLEARED</span>
                                </div>
                                <h2 class="text-2xl font-bold text-white mt-1">
                                    <a href="https://rhinopartners.uk/" target="_blank" class="hover:text-accent transition-colors underline decoration-accent/50 underline-offset-4">Rhino Partners</a>
                                </h2>
                                <h3 class="text-lg text-accent font-medium">Senior Frontend Engineer</h3>
                                <span class="text-sm font-semibold text-gray-400 mt-1">Oct 2019 - Jan 2025</span>
                            </div>
                            <ul class="text-sm text-gray-300 space-y-2">
                                <li><strong class="text-white">Leadership:</strong> Led frontend for 5+ projects & mentored juniors to mid-level.</li>
                                <li><strong class="text-white">Design Systems:</strong> Built MUI themes and shared UI libraries.</li>
                                <li><strong class="text-white">Performance:</strong> Revamped UI, boosted Core Web Vitals & cross-browser support.</li>
                                <li><strong class="text-white">Tech Stack:</strong> Next.js, Redux Toolkit, Figma to pixel-perfect code.</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- Level 01: SevenSigns -->
                <div class="node-reveal flex flex-col md:flex-row items-center md:justify-center relative">
                    <!-- Mobile Connecting Line to Icon -->
                    <div class="absolute -left-5 top-10 w-8 h-[2px] bg-accent md:hidden opacity-50"></div>
                    
                    <div class="w-full md:w-5/12 flex md:justify-end md:pr-12 md:text-right pl-12 md:pl-0">
                        <div class="bg-black/60 backdrop-blur-md border border-accent/30 p-6 rounded-lg shadow-[0_0_20px_rgba(171,32,253,0.15)] hover:shadow-[0_0_30px_rgba(171,32,253,0.4)] transition-all duration-300 transform hover:-translate-y-1 relative">
                            <div class="flex flex-col md:items-end mb-4">
                                <div class="flex items-center gap-2 mb-1">
                                    <span class="text-xs font-bold text-accent border border-accent rounded px-2 py-0.5">LVL 01</span>
                                    <span class="text-xs font-bold text-gray-400 border border-gray-600 rounded px-2 py-0.5 bg-gray-600/10">CLEARED</span>
                                </div>
                                <h2 class="text-2xl font-bold text-white mt-1">
                                    <a href="#" target="_blank" class="hover:text-accent transition-colors underline decoration-accent/50 underline-offset-4">SevenSigns</a>
                                </h2>
                                <h3 class="text-lg text-accent font-medium">Frontend developer</h3>
                                <span class="text-sm font-semibold text-gray-400 mt-1">Dec 2016 - Aug 2018</span>
                            </div>
                            <ul class="text-sm text-gray-300 md:text-right space-y-2">
                                <li><strong class="text-white">WordPress & UI:</strong> Responsive WP themes, PSD tracking to HTML/CSS via Bootstrap/jQuery.</li>
                                <li><strong class="text-white">Performance:</strong> Core Web Vitals optimizations from PageSpeed Insights.</li>
                                <li><strong class="text-white">Workflow:</strong> SCSS, Gulp/Grunt build automation.</li>
                            </ul>
                        </div>
                    </div>

                    <!-- Icon / Avatar -->
                    <div class="absolute left-0 top-6 md:static md:top-auto shrink-0 z-20 mx-auto md:mx-0 w-16 h-16 md:w-24 md:h-24 bg-black rounded-full border-2 border-accent flex items-center justify-center node-icon-pulse overflow-hidden group shadow-[0_0_15px_rgba(171,32,253,0.6)]">
                        <svg viewBox="0 0 100 100" class="w-10 h-10 md:w-14 md:h-14 text-white group-hover:scale-110 transition-transform duration-300" fill="currentColor">
                            <rect x="25" y="25" width="50" height="50" rx="10" opacity="0.2" fill="#ab20fd" transform="rotate(45 50 50)"/>
                            <rect x="20" y="20" width="60" height="60" rx="12" stroke="#ab20fd" stroke-width="2" fill="none" transform="rotate(45 50 50)"/>
                            <!-- Abstract scroll/book -->
                            <path d="M35 35 L65 35 L65 65 L35 65 Z" fill="none" stroke="#ab20fd" stroke-width="3"/>
                            <line x1="42" y1="45" x2="58" y2="45" stroke="#ab20fd" stroke-width="2"/>
                            <line x1="42" y1="55" x2="52" y2="55" stroke="#ab20fd" stroke-width="2"/>
                        </svg>
                    </div>

                    <div class="w-full md:w-5/12 hidden md:block pl-12">
                        <!-- Empty spacer for desktop alternating layout -->
                    </div>
                </div>

            </div>
        </div>
    </main>

    <script>
        // Intersection Observer for Scroll Reveal Animations
        document.addEventListener("DOMContentLoaded", () => {
            const observerOptions = {
                root: null,
                rootMargin: '0px',
                threshold: 0.15
            };

            const observer = new IntersectionObserver((entries, observer) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible');
                        // Optional: unobserve if you only want it to animate once
                        // observer.unobserve(entry.target); 
                    }
                });
            }, observerOptions);

            const nodes = document.querySelectorAll('.node-reveal');
            nodes.forEach((node, index) => {
                // Add slight delay for staggered effect if multiple are visible at once
                (node as HTMLElement).style.transitionDelay = `${index * 150}ms`;
                observer.observe(node);
            });
        });
    </script>

</PageLayout>
