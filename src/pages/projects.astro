---
import PageLayout from "../layouts/PageLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
    (a, b: any) =>
        new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf(),
);
---

<PageLayout title="Projects" description="My projects">
    <main class="py-8 pb-32">
        <div class="container mb-4 lg:mb-8">
            <h1 class="text-2xl lg:text-4xl font-bold font-geistmono">
                Projects
            </h1>

            <ul class="mt-8 flex flex-col gap-2">
                <li class="leading-none">
                    <a
                        href="https://json-to-what.vercel.app/"
                        target="_blank"
                        class="p-1 rounded-sm underline transition-colors delay-300 ease-in-out hover:bg-accent"
                        >Json to What</a
                    >
                </li>
            </ul>
        </div>
    </main>
</PageLayout>
